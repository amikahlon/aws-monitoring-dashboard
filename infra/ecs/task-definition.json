{
  "family": "aws-monitoring-dashboard-dev-task",
  "networkMode": "bridge",
  "requiresCompatibilities": ["EC2"],
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "REPLACE_BACKEND_IMAGE",
      "essential": true,
      "cpu": 128,
      "memory": 256,
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        },
        {
          "name": "PORT",
          "value": "4000"
        }
      ],
      "portMappings": [
        {
          "containerPort": 4000,
          "hostPort": 4000,
          "protocol": "tcp"
        }
      ]
    },
    {
      "name": "frontend",
      "image": "REPLACE_FRONTEND_IMAGE",
      "essential": true,
      "cpu": 128,
      "memory": 256,
      "links": ["backend"],
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ]
    }
  ]
}